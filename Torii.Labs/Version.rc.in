#include <winres.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @TORII_LABS_VERSION_COMMA@
 PRODUCTVERSION @TORII_LABS_VERSION_COMMA@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Torii\0"
            VALUE "FileDescription", "Torii Labs\0"
            VALUE "FileVersion", "@TORII_LABS_VERSION_LABEL@\0"
            VALUE "InternalName", "ToriiLabs\0"
            VALUE "OriginalFilename", "ToriiLabs.exe\0"
            VALUE "ProductName", "Torii Labs\0"
            VALUE "ProductVersion", "@TORII_LABS_VERSION_LABEL@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
